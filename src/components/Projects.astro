---
import { projects, asset } from "../lib/site";
import Media from "./Media.astro";

const featured = projects.filter((p) => p.featured);
const others = projects.filter((p) => !p.featured);

// Rarity → accent color used for stripes, borders and badges.
const tierColor: Record<string, string> = {
  legendary: "var(--accent)",
  epic: "#A78BFA",
  rare: "#60A5FA",
  common: "#94A3B8",
};
const tierOf = (t: string) => tierColor[t] ?? tierColor.common;

// Collapsed thumbnail: prefer an explicit `thumbnail`, else fall back to the
// hero's poster, else the hero source itself.
const thumbOf = (p: any) => p.thumbnail ?? p.hero.poster ?? p.hero.src;
---

<section class="arsenal">
  <div class="section-head">
    <p class="kicker">Loadout</p>
    <h2 class="section-title">Arsenal</h2>
    <p class="section-sub">Gear I've built. The Legendary sits up top.</p>
  </div>

  {/* Featured / Legendary card */}
  {featured.map((p) => (
    <article id="featured" class="card featured" data-tier={p.tier} style={`--tier:${tierOf(p.tier)}`}>
      <div class="asset">
        <span class="rarity-badge">
          <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" aria-hidden="true"><path d="M2.5 7.5 7 11l5-6.5L17 11l4.5-3.5-1.8 11.3a1 1 0 0 1-1 .82H5.3a1 1 0 0 1-1-.82L2.5 7.5Z"/></svg>
          {p.tier} · Featured
        </span>
        <Media hero={p.hero} name={p.name} autoplay />
      </div>
      <div class="body">
        <h3 class="proj-name">{p.name}</h3>
        <p class="proj-blurb">{p.blurb}</p>
        <div class="tags">
          {p.tech.map((t) => (
            <span class="tag">
              <svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor" aria-hidden="true"><path d="M12 2 21 7v10l-9 5-9-5V7z"/></svg>
              {t}
            </span>
          ))}
        </div>
        {p.links.length > 0 && (
          <div class="links">
            {p.links.map((l) => (
              <a class="link-btn" href={l.url} target="_blank" rel="noopener">{l.label} ↗</a>
            ))}
          </div>
        )}
      </div>
    </article>
  ))}

  {/* Other projects — collapse the compact row, expand into the featured layout */}
  <div id="other" class="others">
    {others.map((p) => (
      <article class="card proj-card" data-tier={p.tier} style={`--tier:${tierOf(p.tier)}`}>
        {/* Collapsed: compact row */}
        <div class="head-wrap">
          <div class="clip">
            <button
              type="button"
              class="card-head"
              aria-expanded="false"
              aria-controls={`more-${p.slug}`}
            >
              <img class="thumb" src={asset(thumbOf(p))} alt={p.name} loading="lazy" />
              <div class="card-meta">
                <div class="card-top">
                  <h3 class="proj-name sm">{p.name}</h3>
                  <span class="tier-chip">{p.tier}</span>
                </div>
                <p class="proj-blurb sm">{p.blurb}</p>
                <div class="tags">
                  {p.tech.map((t) => (
                    <span class="tag">
                      <svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor" aria-hidden="true"><path d="M12 2 21 7v10l-9 5-9-5V7z"/></svg>
                      {t}
                    </span>
                  ))}
                </div>
              </div>
              <svg class="chevron" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
            </button>
          </div>
        </div>

        {/* Expanded: featured-style layout — media first, then body */}
        <div class="card-more" id={`more-${p.slug}`}>
          <div class="clip">
            <div class="asset exp-asset">
              <Media hero={p.hero} name={p.name} />
            </div>
            <div class="body">
              <div class="body-top">
                <div class="card-top">
                  <h3 class="proj-name">{p.name}</h3>
                  <span class="tier-chip">{p.tier}</span>
                </div>
                <button type="button" class="collapse-btn" aria-label="Collapse">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m18 15-6-6-6 6"/></svg>
                </button>
              </div>
              <p class="proj-blurb">{p.blurb}</p>
              <div class="tags">
                {p.tech.map((t) => (
                  <span class="tag">
                    <svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor" aria-hidden="true"><path d="M12 2 21 7v10l-9 5-9-5V7z"/></svg>
                    {t}
                  </span>
                ))}
              </div>
              {p.links.length > 0 && (
                <div class="links">
                  {p.links.map((l) => (
                    <a class="link-btn" href={l.url} target="_blank" rel="noopener">{l.label} ↗</a>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .arsenal {
    max-width: 60rem;
    margin: 0 auto;
    padding: 5rem 1.5rem 6rem;
  }
  .section-head {
    margin-bottom: 2rem;
  }
  .kicker {
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--accent-strong);
  }
  [data-theme="dark"] .kicker { color: var(--accent); }
  .section-title {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-top: 0.3rem;
  }
  .section-sub {
    color: var(--text-muted);
    margin-top: 0.4rem;
  }

  /* --- Shared card shell --- */
  .card {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-left: 3px solid var(--tier);
    border-radius: 16px;
    overflow: hidden;
  }

  /* Shared 16:9 asset frame (featured + expanded others) */
  .asset {
    position: relative;
    aspect-ratio: 16 / 9;
    background: #0b0f12;
    overflow: hidden;
  }

  .proj-name {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .proj-name.sm { font-size: 1.1rem; }
  .proj-blurb {
    margin-top: 0.4rem;
    color: var(--text-muted);
    line-height: 1.55;
  }
  .proj-blurb.sm { margin-top: 0.25rem; font-size: 0.9rem; }

  /* Code-style "mod chip" tech tags */
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.85rem;
  }
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text);
    padding: 0.28rem 0.6rem;
    border-radius: 8px;
    background: color-mix(in srgb, var(--accent) 9%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--border));
    transition: background-color 0.16s ease, border-color 0.16s ease;
  }
  .tag svg { color: var(--accent-strong); flex-shrink: 0; }
  [data-theme="dark"] .tag svg { color: var(--accent); }
  .tag:hover {
    background: color-mix(in srgb, var(--accent) 16%, transparent);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.1rem;
  }
  .link-btn {
    font-size: 0.82rem;
    font-weight: 600;
    padding: 0.45rem 0.85rem;
    border-radius: 10px;
    color: var(--accent-strong);
    background: var(--accent-soft);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    transition: background-color 0.16s ease, transform 0.16s ease;
  }
  [data-theme="dark"] .link-btn { color: var(--accent); }
  .link-btn:hover {
    transform: translateY(-1px);
    background: color-mix(in srgb, var(--accent) 18%, transparent);
  }

  .body {
    padding: 1.3rem 1.5rem 1.6rem;
  }

  /* --- Featured / Legendary --- */
  .featured {
    border-left-width: 4px;
    box-shadow: 0 0 0 1px var(--accent-soft), 0 18px 50px -22px var(--ring);
  }
  .rarity-badge {
    position: absolute;
    top: 0.9rem;
    left: 0.9rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: var(--tier);
    color: #062019;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    box-shadow: 0 4px 18px var(--ring);
  }

  /* --- Others / accordion --- */
  .others {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    margin-top: 1.2rem;
  }
  .proj-card {
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .proj-card:not(.open):hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px -18px rgba(0, 0, 0, 0.5);
    border-color: color-mix(in srgb, var(--tier) 55%, var(--border));
  }

  /* Both halves collapse/expand with a synced height animation */
  .head-wrap,
  .card-more {
    display: grid;
    transition: grid-template-rows 0.36s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .head-wrap { grid-template-rows: 1fr; }
  .card-more { grid-template-rows: 0fr; }
  .proj-card.open .head-wrap { grid-template-rows: 0fr; }
  .proj-card.open .card-more { grid-template-rows: 1fr; }
  .clip { overflow: hidden; }

  .card-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    text-align: left;
    padding: 0.9rem;
    background: transparent;
    border: 0;
    cursor: pointer;
    color: inherit;
    font: inherit;
  }
  .thumb {
    width: 78px;
    height: 78px;
    border-radius: 10px;
    object-fit: cover;
    flex-shrink: 0;
    background: #0b0f12;
  }
  .card-meta { min-width: 0; flex: 1; }
  .card-top {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .tier-chip {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--tier);
    border: 1px solid color-mix(in srgb, var(--tier) 45%, transparent);
    padding: 0.12rem 0.4rem;
    border-radius: 999px;
    white-space: nowrap;
  }
  .chevron {
    flex-shrink: 0;
    color: var(--text-muted);
  }

  /* Expanded body header: name/tier on the left, collapse control on the right */
  .body-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }
  .collapse-btn {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 9px;
    color: var(--text-muted);
    background: transparent;
    border: 1px solid var(--border);
    cursor: pointer;
    transition: color 0.16s ease, border-color 0.16s ease, background-color 0.16s ease;
  }
  .collapse-btn:hover {
    color: var(--tier);
    border-color: color-mix(in srgb, var(--tier) 45%, transparent);
    background: color-mix(in srgb, var(--tier) 10%, transparent);
  }

  /* Expanded asset reveal — fades/scales in after the card opens */
  .exp-asset {
    opacity: 0;
    transform: scale(1.04);
    transition: opacity 0.45s ease, transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .proj-card.open .exp-asset {
    opacity: 1;
    transform: none;
  }
  .proj-card .card-more .body {
    opacity: 0;
    transition: opacity 0.4s ease 0.12s;
  }
  .proj-card.open .card-more .body { opacity: 1; }

  @media (max-width: 767px) {
    .thumb { width: 62px; height: 62px; }
    .proj-name.sm { font-size: 1rem; }
  }
</style>

<script>
  // Accordion: one open at a time. The compact row collapses as the
  // featured-style body expands. Videos play on open, pause/reset on close.
  const cards = document.querySelectorAll<HTMLElement>(".proj-card");

  function setOpen(card: HTMLElement, open: boolean) {
    card.classList.toggle("open", open);
    card.querySelector(".card-head")?.setAttribute("aria-expanded", String(open));
    const vid = card.querySelector<HTMLVideoElement>("video[data-video]");
    if (vid) {
      if (open) vid.play().catch(() => {});
      else { vid.pause(); vid.currentTime = 0; }
    }
  }

  cards.forEach((card) => {
    card.querySelector(".card-head")?.addEventListener("click", () => {
      const isOpen = card.classList.contains("open");
      cards.forEach((c) => { if (c !== card) setOpen(c, false); });
      setOpen(card, !isOpen);
    });
    card.querySelector(".collapse-btn")?.addEventListener("click", () => setOpen(card, false));
  });
</script>
