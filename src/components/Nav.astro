---
// Floating navigation: desktop pill (top-center) + mobile hamburger (top-right).
// Includes an XP progress bar that doubles as the active-section indicator.
const items = [
  { id: "about", label: "About", type: "scroll" },
  { id: "featured", label: "Featured", type: "scroll" },
  { id: "other", label: "Other", type: "scroll" },
  { id: "contact", label: "Contact", type: "modal" },
];
---

<header class="nav-root">
  {/* XP / scroll-progress HUD */}
  <div class="xp" aria-hidden="true">
    <div class="xp-track">
      <div class="xp-fill" id="xp-fill"></div>
    </div>
    <span class="xp-label" id="xp-label">ABOUT</span>
  </div>

  {/* Desktop pill */}
  <nav class="pill" aria-label="Primary">
    {items.map((item) =>
      item.type === "modal" ? (
        <button type="button" class="pill-item" data-nav={item.id} data-open-contact>
          {item.label}
        </button>
      ) : (
        <a href={`#${item.id}`} class="pill-item" data-nav={item.id}>
          {item.label}
        </a>
      )
    )}
  </nav>

  {/* Mobile hamburger */}
  <div class="mobile">
    <button
      type="button"
      class="burger"
      id="burger"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span><span></span><span></span>
    </button>
    <nav class="mobile-menu" id="mobile-menu" aria-label="Primary" hidden>
      {items.map((item) =>
        item.type === "modal" ? (
          <button type="button" class="mobile-item" data-nav={item.id} data-open-contact>
            {item.label}
          </button>
        ) : (
          <a href={`#${item.id}`} class="mobile-item" data-nav={item.id}>
            {item.label}
          </a>
        )
      )}
    </nav>
  </div>
</header>

<style>
  .nav-root {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    pointer-events: none;
  }
  .nav-root > * {
    pointer-events: auto;
  }

  /* --- XP / scroll-progress HUD --- */
  .xp {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.75rem 0;
  }
  .xp-track {
    flex: 1;
    height: 3px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--text) 12%, transparent);
    overflow: hidden;
  }
  .xp-fill {
    height: 100%;
    width: 0%;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--accent-strong), var(--accent));
    box-shadow: 0 0 8px var(--ring);
    transition: width 0.15s ease-out;
  }
  .xp-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--accent);
    min-width: 4.5ch;
    text-align: right;
  }

  /* --- Desktop pill --- */
  .pill {
    position: fixed;
    top: 1.1rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.25rem;
    padding: 0.3rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--bg-elev) 70%, transparent);
    border: 1px solid var(--border);
    backdrop-filter: blur(12px) saturate(140%);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
  }
  .pill-item {
    font: inherit;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    transition: color 0.18s ease, background-color 0.18s ease;
  }
  .pill-item:hover {
    color: var(--text);
  }
  .pill-item.active {
    color: var(--accent-strong);
    background: var(--accent-soft);
  }
  [data-theme="dark"] .pill-item.active {
    color: var(--accent);
  }

  /* --- Mobile hamburger --- */
  .mobile {
    display: none;
    position: fixed;
    top: 0.9rem;
    right: 0.9rem;
  }
  .burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 0 11px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--bg-elev) 70%, transparent);
    border: 1px solid var(--border);
    backdrop-filter: blur(12px) saturate(140%);
    cursor: pointer;
  }
  .burger span {
    display: block;
    height: 2px;
    width: 100%;
    border-radius: 2px;
    background: var(--text);
    transition: transform 0.22s ease, opacity 0.18s ease;
  }
  .burger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .burger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .burger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
  .mobile-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 10rem;
    padding: 0.4rem;
    border-radius: 14px;
    background: color-mix(in srgb, var(--bg-elev) 88%, transparent);
    border: 1px solid var(--border);
    backdrop-filter: blur(14px) saturate(140%);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.2);
    transform-origin: top right;
    animation: menu-in 0.16s ease-out;
  }
  .mobile-menu[hidden] {
    display: none;
  }
  @keyframes menu-in {
    from { opacity: 0; transform: scale(0.95) translateY(-4px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  .mobile-item {
    font: inherit;
    text-align: left;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-muted);
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 0.65rem 0.8rem;
    border-radius: 10px;
    transition: color 0.16s ease, background-color 0.16s ease;
  }
  .mobile-item:hover,
  .mobile-item.active {
    color: var(--accent-strong);
    background: var(--accent-soft);
  }
  [data-theme="dark"] .mobile-item.active {
    color: var(--accent);
  }

  @media (max-width: 767px) {
    .pill { display: none; }
    .mobile { display: block; }
  }
</style>

<script>
  const burger = document.getElementById("burger");
  const menu = document.getElementById("mobile-menu");
  const xpFill = document.getElementById("xp-fill");
  const xpLabel = document.getElementById("xp-label");

  // --- Mobile menu toggle ---
  function setMenu(open: boolean) {
    if (!burger || !menu) return;
    burger.setAttribute("aria-expanded", String(open));
    burger.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    menu.hidden = !open;
  }
  burger?.addEventListener("click", (e) => {
    e.stopPropagation();
    setMenu(menu?.hidden ?? true);
  });
  document.addEventListener("click", (e) => {
    if (!menu || menu.hidden) return;
    const target = e.target as Node;
    if (!menu.contains(target) && !burger?.contains(target)) setMenu(false);
  });
  menu?.querySelectorAll(".mobile-item").forEach((el) =>
    el.addEventListener("click", () => setMenu(false))
  );
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") setMenu(false);
  });

  // --- Contact buttons dispatch an event the modal will later listen for ---
  document.querySelectorAll("[data-open-contact]").forEach((el) =>
    el.addEventListener("click", () =>
      document.dispatchEvent(new CustomEvent("open-contact"))
    )
  );

  // --- XP / scroll progress ---
  function updateXp() {
    const scrollable = document.documentElement.scrollHeight - window.innerHeight;
    const pct = scrollable > 0 ? (window.scrollY / scrollable) * 100 : 0;
    if (xpFill) xpFill.style.width = `${Math.min(100, Math.max(0, pct))}%`;
  }
  window.addEventListener("scroll", updateXp, { passive: true });
  window.addEventListener("resize", updateXp);
  updateXp();

  // --- Active-section scroll spy ---
  const navTargets = ["about", "featured", "other"];
  function setActive(id: string) {
    document.querySelectorAll("[data-nav]").forEach((el) => {
      el.classList.toggle("active", el.getAttribute("data-nav") === id);
    });
    if (xpLabel) xpLabel.textContent = id.toUpperCase();
  }
  const observer = new IntersectionObserver(
    (entries) => {
      const visible = entries
        .filter((e) => e.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
      if (visible) setActive(visible.target.id);
    },
    { rootMargin: "-45% 0px -45% 0px", threshold: [0, 0.25, 0.5, 1] }
  );
  navTargets.forEach((id) => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });
</script>
