---
import Base from "../layouts/Base.astro";
---

<Base>
  <main class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center">
      <p class="text-sm uppercase tracking-widest" style="color: var(--accent)">
        Loadout — v0.1
      </p>
      <h1 class="mt-4 text-4xl sm:text-6xl font-bold">
        Maverick Luke
      </h1>
      <p class="mt-3 text-lg" style="color: var(--text-muted)">
        I don't just play games, I build them.
      </p>
      <p class="mt-8 text-sm" style="color: var(--text-muted)">
        Site under construction. Real content coming shortly.
      </p>
    </div>
  </main>
</Base>
